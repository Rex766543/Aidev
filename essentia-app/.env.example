# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_ENV=development

# ─────────────────────────────────────────
# Backend
# ─────────────────────────────────────────

# ローカル開発: PostgreSQL (docker-compose の db サービス)
DATABASE_URL=postgresql://postgres:postgres@db:5432/essentia

# 本番: Supabase の接続文字列に差し替え
# DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# CORS 許可オリジン (カンマ区切り)
CORS_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────
# Spotify API (Client Credentials flow)
# https://developer.spotify.com/dashboard で取得
# ─────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ─────────────────────────────────────────
# Essentia モデル設定
# scripts/download_models.sh で models/ に配置してから起動
# ─────────────────────────────────────────
MODELS_DIR=/app/models
ESSENTIA_MODEL_PB=discogs-effnet-bs64-1.pb
ESSENTIA_MODEL_JSON=discogs-effnet-bs64-1.json
ESSENTIA_MODEL_NAME=discogs-effnet
ESSENTIA_MODEL_VERSION=bs64-1

# 録音の最大秒数
MAX_AUDIO_SECONDS=20

# ─────────────────────────────────────────
# Frontend
# ─────────────────────────────────────────

# ブラウザ（クライアント側）から見える backend のアドレス
NEXT_PUBLIC_API_URL=http://localhost:8000
# SSR（サーバー側）から見える backend のアドレス（Docker 内部ネットワーク）
INTERNAL_API_URL=http://backend:8000

# ─────────────────────────────────────────
# Supabase (本番 / ローカル Supabase CLI)
# ─────────────────────────────────────────

# Supabase MCP 用アクセストークン
SUPABASE_ACCESS_TOKEN=

# Supabase プロジェクト URL と anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
